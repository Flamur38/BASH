#!/usr/bin/env bash

# Run the Ghostty install script from the mkasberg repository
/bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/mkasberg/ghostty-ubuntu/HEAD/install.sh)"

# Download the appropriate .deb package for Ubuntu 24.04
wget -O /tmp/ghostty.deb https://github.com/mkasberg/ghostty-ubuntu/releases/download/1.1.3-0-ppa2/ghostty_1.1.3-0.ppa2_amd64_24.04.deb

# Install the .deb package
sudo dpkg -i /tmp/ghostty.deb

# Fix any missing dependencies
sudo apt-get install -f -y

# Optional: clean up
rm /tmp/ghostty.deb

