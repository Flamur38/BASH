#!/usr/bin/env bash

GREEN="\033[0;32m"
RESET="\033[0m"

# Helper function for clean status
status() {
    echo -e "${GREEN}======= $1 =======${RESET}"
}

# 1. Install base packages
status "Installing Base Packages"
sudo apt install terminator build-essential python3 python3-pip tcpdump htop zsh bat dirb whois rdesktop nodejs ripgrep fd-find xclip flameshot

# 2. Fix missing npm (Ubuntu issue)
if ! command -v npm &>/dev/null; then
    status "Installing npm manually"
    sudo apt install -y npm
fi

# 3. Configure npm for local user
if command -v npm &>/dev/null; then
    status "Configuring npm for local user"
    mkdir -p "$HOME/.npm-global"
    npm config set prefix "$HOME/.npm-global"
    export PATH="$HOME/.npm-global/bin:$PATH"

    # 4. Install pyright
    status "Installing pyright globally via npm"
    npm install -g pyright
else
    status "npm is still missing, skipping pyright installation"
fi

# 5. Symlink fd if needed
if ! command -v fd &>/dev/null && command -v fdfind &>/dev/null; then
    status "Creating symlink: fd -> fdfind"
    mkdir -p "$HOME/.local/bin"
    ln -sf "$(which fdfind)" "$HOME/.local/bin/fd"
    export PATH="$HOME/.local/bin:$PATH"
fi

# 6. Install fzf if not already installed
if [[ ! -d "$HOME/.fzf" ]]; then
    status "Cloning and Installing fzf"
    git clone --depth 1 https://github.com/junegunn/fzf.git "$HOME/.fzf"
    "$HOME/.fzf/install" --all
else
    status "fzf already installed"
fi

# 7. Install Google Chrome if missing
if ! command -v google-chrome &>/dev/null; then
    status "Installing Google Chrome"
    wget -q -O /tmp/google-chrome.deb https://dl.google.com/linux/direct/google-chrome-stable_current_amd64.deb
    sudo apt install -y /tmp/google-chrome.deb
    rm /tmp/google-chrome.deb
    status "Google Chrome installed"
else
    status "Google Chrome already installed"
fi

status "All tools installed and configured"

